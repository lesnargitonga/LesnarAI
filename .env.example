# Example environment file for smoke tests.
# Do not use these values for any real deployment.
# For local use, copy this file to .env and set strong values.

POSTGRES_USER=lesnar
POSTGRES_PASSWORD=example-password
POSTGRES_DB=lesnar

# API keys used by the backend (X-API-Key)
LESNAR_ADMIN_API_KEY=example-admin-key
LESNAR_OPERATOR_API_KEY=example-operator-key

# Security controls
LESNAR_REQUIRE_AUTH=1
LESNAR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LESNAR_ENFORCE_AUDIT_CHAIN=1
LESNAR_AUDIT_CHAIN_KEY=replace-with-strong-random-secret
LESNAR_DATASET_SIGN_KEY=replace-with-strong-random-secret
FLASK_SECRET_KEY=replace-with-strong-random-secret

# Session auth (preferred over browser-exposed API keys)
# Generate JSON with: python3 scripts/generate_auth_users_json.py --user admin:admin:StrongPass --user ops:operator:StrongPass
LESNAR_AUTH_USERS_JSON=[]
LESNAR_SESSION_TTL_S=1800

# Server-side operational geofence (JSON array of [lat, lng])
LESNAR_OPERATIONAL_BOUNDARY=[]

# Telemetry / replay controls
LESNAR_EXTERNAL_TELEMETRY_STALE_AFTER_S=5.0
LESNAR_COMMAND_CONFIRM_TIMEOUT_S=2.5
LESNAR_TELEMETRY_HISTORY_INTERVAL_TICKS=5

# Feature flags
LESNAR_USE_AIRSIM=0
ALLOW_UNSAFE_WERKZEUG=1
AUTO_MIGRATE=1
