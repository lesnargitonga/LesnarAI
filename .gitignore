# ============================
# Lesnar AI — .gitignore
# ============================

# ---------- Python ----------
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.whl

# ---------- Virtual Environments ----------
.venv/
.venv-wsl/
backend-env/
legacy/

# ---------- Node / Frontend ----------
node_modules/
frontend/build/

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.code-workspace
.qodo/

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Secrets (NEVER commit) ----------
.env
.env.*
!.env.example

# ---------- External / Large Dependencies ----------
externals/

# ---------- Data, Logs & Training Artifacts ----------
datasets/
dataset/
data/
logs/
runs/
lightning_logs/
*.ulg
*.bag
*.npz
*.log
*.csv

# ---------- Build / Cache ----------
*.egg-info/

# ---------- Models (large binaries) ----------
# Uncomment to exclude trained model files from Git:
# models/*.pth
# models/*.pt
# models/*.onnx
