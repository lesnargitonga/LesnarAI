# Frontend secure deployment example
# Copy to frontend/.env.local for local secure runs.

# Require backend session login before showing the control UI.
REACT_APP_REQUIRE_SESSION_AUTH=1

# Keep browser-exposed API key fallback disabled in secure deployments.
REACT_APP_ALLOW_LEGACY_API_KEY=0

# Offline/local map tiles. Leave blank to use configured fallback.
# Example: http://localhost:8081/tiles/{z}/{x}/{y}.png
REACT_APP_MAP_TILE_URL=
REACT_APP_MAP_TILE_ATTRIBUTION=Local tactical tiles
REACT_APP_MAP_TILE_FALLBACK_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png

# Client-side visualization of the operational geofence.
# Must match the backend boundary for full enforcement.
REACT_APP_OPERATIONAL_BOUNDARY=[]

# Link posture thresholds
REACT_APP_TELEMETRY_STALE_MS=3000
REACT_APP_DEGRADED_LATENCY_MS=1200
REACT_APP_DEGRADED_TELEMETRY_MS=4000
